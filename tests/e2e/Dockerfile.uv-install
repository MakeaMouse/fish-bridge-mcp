# Smoke test: uv tool install from local wheel
# Build this from the repo root with:
#   docker build -f tests/e2e/Dockerfile.uv-install -t fb-uv-install .
#   docker run --rm fb-uv-install

FROM python:3.12-slim

# Install uv
RUN pip install --no-cache-dir uv

WORKDIR /app

# Copy the wheel and fixtures (built beforehand with: python -m build --wheel)
COPY dist/fish_bridge_mcp-*.whl /tmp/
COPY tests/fixtures/ /app/tests/fixtures/

# Install via uv tool install
RUN uv tool install /tmp/fish_bridge_mcp-*.whl

# Ensure the uv tools bin is on PATH
ENV PATH="/root/.local/bin:$PATH"

# --- Smoke tests ---
RUN fish-bridge --help > /dev/null
RUN fish-bridge config --show 2>&1 | grep -i backend
RUN fish-bridge init --project /tmp/smoke-init --tool copilot && ls /tmp/smoke-init/
# (ingest omitted: requires a live backend — claude/openai/gemini need API keys,
#  local needs Ollama. Entry point installation is what we verify here.)

# MCP server handshake
RUN printf '{"jsonrpc":"2.0","id":1,"method":"initialize","params":{"protocolVersion":"2024-11-05","capabilities":{},"clientInfo":{"name":"docker-test","version":"1"}}}\n' \
    | timeout 5 fish-bridge-mcp 2>/dev/null \
    | head -1 \
    | python3 -c "import sys,json; d=json.load(sys.stdin); assert 'result' in d, d; print('MCP OK')"

CMD ["echo", "All Docker smoke tests passed"]
